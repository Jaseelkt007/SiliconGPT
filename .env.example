# Copy this file to ".env" and fill in your keys.  ->  cp .env.example .env
# .env is gitignored — NEVER commit real keys.
# The harness (scripts/llm_baseline.py) auto-loads .env via python-dotenv.

OPENAI_API_KEY=
GEMINI_API_KEY=
MOONSHOT_API_KEY=        # Kimi K2 (Moonshot)  — provider name: kimi
ANTHROPIC_API_KEY=       # Claude             — provider name: anthropic

# Future / optional open-source LLM providers (OpenAI-compatible) — add when needed:
# TOGETHER_API_KEY=
# OPENROUTER_API_KEY=
# DEEPSEEK_API_KEY=
